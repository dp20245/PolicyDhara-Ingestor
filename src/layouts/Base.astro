---
import '../styles/global.css';
import NewsTicker from '../components/NewsTicker.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "PolicyDhara — open-source tracker of Indian development policies across 20+ sectors. By ImpactMojo." } = Astro.props;
const siteTitle = `${title} | PolicyDhara`;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const canonicalUrl = Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  {/* Open Graph */}
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="PolicyDhara" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="en_IN" />

  {/* Twitter / X Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={description} />

  {/* Additional SEO */}
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#2563eb" />
  <meta name="author" content="ImpactMojo" />
  <meta name="keywords" content="India policy tracker, Indian government policies, development policy, PIB, legislation, schemes, budget, parliament, open data, policy analysis" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Newsreader:wght@400;600;700&display=swap" rel="stylesheet" />

  <link rel="alternate" type="application/rss+xml" title="PolicyDhara RSS" href={`${base}rss.xml`} />

  {/* JSON-LD Structured Data */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "PolicyDhara",
    "description": "Open-source tracker of Indian development policies across 20+ sectors",
    "url": canonicalUrl,
    "publisher": {
      "@type": "Organization",
      "name": "ImpactMojo",
      "url": "https://www.impactmojo.in"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${base}search/?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  })} />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href={base} class="site-logo">
        <div class="logo-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <div>
          <h1>PolicyDhara</h1>
          <span class="subtitle">by ImpactMojo</span>
        </div>
      </a>
      <nav class="header-nav">
        <div class="nav-primary">
          <a href={base}>Home</a>
          <a href={`${base}search/`}>Search</a>
          <a href={`${base}sectors/`}>Sectors</a>
          <a href={`${base}alerts/`}>Alerts</a>
          <div class="nav-dropdown" id="nav-explore">
            <button class="nav-dropdown-trigger">
              Explore
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="nav-dropdown-menu">
              <a href={`${base}budget/`}>
                <span class="nav-menu-icon">$</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Budget</span>
                  <span class="nav-menu-desc">Union budget tracking and fiscal analysis</span>
                </span>
              </a>
              <a href={`${base}parliament/`}>
                <span class="nav-menu-icon">P</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Parliament</span>
                  <span class="nav-menu-desc">Bills, debates, and legislative activity</span>
                </span>
              </a>
              <a href={`${base}intelligence/`}>
                <span class="nav-menu-icon">I</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Intelligence</span>
                  <span class="nav-menu-desc">AI-powered policy insights and trends</span>
                </span>
              </a>
              <a href={`${base}graph/`}>
                <span class="nav-menu-icon">G</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Knowledge Graph</span>
                  <span class="nav-menu-desc">Visual map of policy connections across sectors</span>
                </span>
              </a>
              <a href={`${base}continuity/`}>
                <span class="nav-menu-icon">C</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Continuity</span>
                  <span class="nav-menu-desc">Policy evolution across governments</span>
                </span>
              </a>
              <a href={`${base}compare/`}>
                <span class="nav-menu-icon">~</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Compare</span>
                  <span class="nav-menu-desc">Side-by-side policy comparison tool</span>
                </span>
              </a>
              <a href={`${base}amendments/`}>
                <span class="nav-menu-icon">A</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Amendments</span>
                  <span class="nav-menu-desc">Track policy changes and text diffs</span>
                </span>
              </a>
              <a href={`${base}digest/`}>
                <span class="nav-menu-icon">D</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Daily Digest</span>
                  <span class="nav-menu-desc">Daily summary of policy activity</span>
                </span>
              </a>
              <div class="nav-dropdown-divider"></div>
              <a href={`${base}states/`}>
                <span class="nav-menu-icon">S</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">States</span>
                  <span class="nav-menu-desc">State-level policy tracker</span>
                </span>
              </a>
              <a href={`${base}bookmarks/`}>
                <span class="nav-menu-icon">B</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Reading List</span>
                  <span class="nav-menu-desc">Your bookmarked policies</span>
                </span>
              </a>
              <a href={`${base}sources/`}>
                <span class="nav-menu-icon">#</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">Sources</span>
                  <span class="nav-menu-desc">100+ government, media, and research sources</span>
                </span>
              </a>
              <a href={`${base}api/`}>
                <span class="nav-menu-icon">/</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">API</span>
                  <span class="nav-menu-desc">Open data API for developers</span>
                </span>
              </a>
              <a href={`${base}about/`}>
                <span class="nav-menu-icon">?</span>
                <span class="nav-menu-text">
                  <span class="nav-menu-label">About</span>
                  <span class="nav-menu-desc">About PolicyDhara and ImpactMojo</span>
                </span>
              </a>
            </div>
          </div>
          <a href={`${base}rss.xml`} class="nav-rss" title="RSS Feed">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
          </a>
        </div>

        {/* Three-mode theme toggle: System / Light / Dark */}
        <div class="theme-toggle" id="theme-toggle">
          <button class="theme-opt" id="theme-system" title="System preference" data-theme-mode="system">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </button>
          <button class="theme-opt" id="theme-light" title="Light mode" data-theme-mode="light">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </button>
          <button class="theme-opt" id="theme-dark" title="Dark mode" data-theme-mode="dark">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          </button>
        </div>

        {/* Mobile hamburger */}
        <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </nav>
    </div>
    {/* Mobile navigation overlay */}
    <div class="mobile-nav" id="mobile-nav">
      <a href={base}>Home</a>
      <a href={`${base}search/`}>Search</a>
      <a href={`${base}sectors/`}>Sectors</a>
      <a href={`${base}alerts/`}>Alerts</a>
      <a href={`${base}budget/`}>Budget</a>
      <a href={`${base}parliament/`}>Parliament</a>
      <a href={`${base}intelligence/`}>Intelligence</a>
      <a href={`${base}graph/`}>Knowledge Graph</a>
      <a href={`${base}continuity/`}>Continuity</a>
      <a href={`${base}compare/`}>Compare</a>
      <a href={`${base}amendments/`}>Amendments</a>
      <a href={`${base}digest/`}>Digest</a>
      <a href={`${base}states/`}>States</a>
      <a href={`${base}bookmarks/`}>Reading List</a>
      <a href={`${base}sources/`}>Sources</a>
      <a href={`${base}api/`}>API</a>
      <a href={`${base}about/`}>About</a>
      <a href={`${base}rss.xml`}>RSS Feed</a>
    </div>
  </header>
  <NewsTicker />

  <main class="container">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <strong>PolicyDhara</strong>
          <span>An <a href="https://www.impactmojo.in">ImpactMojo</a> product &middot; Free &amp; open-source under <a href="https://github.com/Varnasr/PolicyDhara/blob/master/LICENSE">MIT License</a></span>
        </div>
        <div class="footer-links">
          <a href={`${base}api/`}>API</a>
          <a href={`${base}rss.xml`}>RSS</a>
          <a href="https://github.com/Varnasr/PolicyDhara">GitHub</a>
        </div>
      </div>
      <div class="footer-legal">
        <div class="footer-legal-row">
          <span>&copy; {new Date().getFullYear()} <a href="https://www.impactmojo.in">ImpactMojo</a>. All rights reserved.</span>
          <span class="footer-legal-sep">&middot;</span>
          <a href="https://www.impactmojo.in/terms">Terms of Use</a>
          <span class="footer-legal-sep">&middot;</span>
          <a href="https://www.impactmojo.in/privacy">Privacy Policy</a>
        </div>
        <p class="footer-compliance">
          Compliant with the Information Technology Act, 2000 and Information Technology (Intermediary Guidelines and Digital Media Ethics Code) Rules, 2021.
          This platform aggregates publicly available government data for informational purposes only and does not constitute legal advice.
          For grievances, contact: <a href="mailto:hello@impactmojo.in">hello@impactmojo.in</a>
        </p>
      </div>
      <div class="footer-bottom">
        Data sourced from 300+ official sources including PIB, PRS Legislative Research, India Code, eGazette, NITI Aayog, data.gov.in, RBI, and more.
        Auto-updated every 6 hours via <a href="https://github.com/Varnasr/PolicyDhara">open-source pipeline</a>.
      </div>
    </div>
  </footer>

  {/* ── Keyboard Shortcut Help Overlay ─── */}
  <div class="kbd-help-overlay" id="kbd-help">
    <div class="kbd-help-panel">
      <h3>Keyboard Shortcuts</h3>
      <div class="kbd-row"><span>Navigate between policies</span><span><kbd>J</kbd> / <kbd>K</kbd></span></div>
      <div class="kbd-row"><span>Open focused policy</span><kbd>Enter</kbd></div>
      <div class="kbd-row"><span>Focus search</span><kbd>/</kbd></div>
      <div class="kbd-row"><span>Toggle light/dark</span><kbd>D</kbd></div>
      <div class="kbd-row"><span>Bookmark focused policy</span><kbd>B</kbd></div>
      <div class="kbd-row"><span>Go home</span><kbd>H</kbd></div>
      <div class="kbd-row"><span>Show this help</span><kbd>?</kbd></div>
      <div class="kbd-row"><span>Close overlay</span><kbd>Esc</kbd></div>
    </div>
  </div>

  {/* ── Global Scripts: Dark Mode + Keyboard Shortcuts + Bookmarks + New-Since-Visit ─── */}
  <script>
    // ── Theme: apply saved or system preference before paint ──
    (function() {
      const saved = localStorage.getItem('pd-theme');
      if (saved === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else if (saved === 'light') {
        document.documentElement.removeAttribute('data-theme');
      } else {
        // System preference
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      }
    })();
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const base = document.querySelector('meta[name="base-url"]')?.getAttribute('content') || '/';

      // ── Three-mode theme toggle ──
      const themeBtns = {
        system: document.getElementById('theme-system'),
        light: document.getElementById('theme-light'),
        dark: document.getElementById('theme-dark'),
      };

      function getActiveThemeMode(): string {
        return localStorage.getItem('pd-theme') || 'system';
      }

      function applyTheme(mode: string) {
        // Remove active from all
        Object.values(themeBtns).forEach(btn => btn?.classList.remove('active'));

        if (mode === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('pd-theme', 'dark');
          themeBtns.dark?.classList.add('active');
        } else if (mode === 'light') {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('pd-theme', 'light');
          themeBtns.light?.classList.add('active');
        } else {
          // System
          localStorage.removeItem('pd-theme');
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
          themeBtns.system?.classList.add('active');
        }
      }

      // Initialize active state
      applyTheme(getActiveThemeMode());

      // Listen for system preference changes
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (!localStorage.getItem('pd-theme')) applyTheme('system');
      });

      // Bind click handlers
      Object.entries(themeBtns).forEach(([mode, btn]) => {
        btn?.addEventListener('click', (e) => {
          e.stopPropagation();
          applyTheme(mode);
        });
      });

      function toggleTheme() {
        const current = getActiveThemeMode();
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        applyTheme(isDark ? 'light' : 'dark');
      }

      // ── Navigation dropdown ──
      const navDropdown = document.getElementById('nav-explore');
      const dropdownTrigger = navDropdown?.querySelector('.nav-dropdown-trigger');

      dropdownTrigger?.addEventListener('click', (e) => {
        e.stopPropagation();
        navDropdown?.classList.toggle('open');
      });

      document.addEventListener('click', () => {
        navDropdown?.classList.remove('open');
      });

      navDropdown?.querySelector('.nav-dropdown-menu')?.addEventListener('click', (e) => {
        e.stopPropagation();
      });

      // ── Mobile hamburger ──
      const hamburger = document.getElementById('nav-hamburger');
      const mobileNav = document.getElementById('mobile-nav');

      hamburger?.addEventListener('click', () => {
        mobileNav?.classList.toggle('open');
        document.body.classList.toggle('mobile-nav-open');
      });

      // ── Keyboard Shortcuts ──
      const kbdHelp = document.getElementById('kbd-help');
      let focusedCardIndex = -1;

      function getVisibleCards(): HTMLElement[] {
        return Array.from(document.querySelectorAll('.policy-card'))
          .filter(c => (c as HTMLElement).offsetParent !== null) as HTMLElement[];
      }

      function focusCard(idx: number) {
        const cards = getVisibleCards();
        if (cards.length === 0) return;
        // Remove previous focus
        document.querySelectorAll('.policy-card.kbd-focused').forEach(c => c.classList.remove('kbd-focused'));
        focusedCardIndex = Math.max(0, Math.min(idx, cards.length - 1));
        const card = cards[focusedCardIndex];
        card.classList.add('kbd-focused');
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        card.style.outline = '2px solid var(--color-accent)';
        card.style.outlineOffset = '2px';
      }

      function clearFocus() {
        document.querySelectorAll('.policy-card.kbd-focused').forEach(c => {
          (c as HTMLElement).style.outline = '';
          (c as HTMLElement).style.outlineOffset = '';
          c.classList.remove('kbd-focused');
        });
        focusedCardIndex = -1;
      }

      document.addEventListener('keydown', (e) => {
        const target = e.target as HTMLElement;
        const isInput = target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable;

        // Esc always closes overlays
        if (e.key === 'Escape') {
          if (kbdHelp?.classList.contains('visible')) {
            kbdHelp.classList.remove('visible');
            return;
          }
          clearFocus();
          return;
        }

        if (isInput) return;

        switch (e.key) {
          case '?':
            e.preventDefault();
            kbdHelp?.classList.toggle('visible');
            break;
          case 'd':
          case 'D':
            e.preventDefault();
            toggleTheme();
            break;
          case '/':
            e.preventDefault();
            const searchInput = document.getElementById('policy-search') as HTMLInputElement;
            if (searchInput) {
              searchInput.focus();
              searchInput.select();
            } else {
              window.location.href = (window as any).__base ? (window as any).__base + 'search/' : '/search/';
            }
            break;
          case 'j':
          case 'J':
            e.preventDefault();
            focusCard(focusedCardIndex + 1);
            break;
          case 'k':
          case 'K':
            e.preventDefault();
            focusCard(focusedCardIndex - 1);
            break;
          case 'Enter':
            if (focusedCardIndex >= 0) {
              const cards = getVisibleCards();
              const link = cards[focusedCardIndex]?.querySelector('.policy-title a') as HTMLAnchorElement;
              if (link) link.click();
            }
            break;
          case 'b':
          case 'B':
            if (focusedCardIndex >= 0) {
              const cards = getVisibleCards();
              const bookBtn = cards[focusedCardIndex]?.querySelector('.bookmark-btn') as HTMLButtonElement;
              if (bookBtn) bookBtn.click();
            }
            break;
          case 'h':
          case 'H':
            window.location.href = '/';
            break;
        }
      });

      // Close kbd help on overlay click
      kbdHelp?.addEventListener('click', (e) => {
        if (e.target === kbdHelp) kbdHelp.classList.remove('visible');
      });

      // ── Bookmarks ──
      function getBookmarks(): string[] {
        return JSON.parse(localStorage.getItem('pd-bookmarks') || '[]');
      }

      function toggleBookmark(id: string) {
        const bm = getBookmarks();
        const idx = bm.indexOf(id);
        if (idx >= 0) bm.splice(idx, 1);
        else bm.push(id);
        localStorage.setItem('pd-bookmarks', JSON.stringify(bm));
        return idx < 0; // true if added
      }

      // Initialize bookmark buttons
      const bookmarks = getBookmarks();
      document.querySelectorAll('.bookmark-btn').forEach(btn => {
        const id = (btn as HTMLElement).dataset.policyId || '';
        if (bookmarks.includes(id)) btn.classList.add('bookmarked');
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          e.preventDefault();
          const added = toggleBookmark(id);
          btn.classList.toggle('bookmarked', added);
        });
      });

      // ── New Since Last Visit ──
      const lastVisit = localStorage.getItem('pd-last-visit');
      const now = new Date().toISOString();

      if (lastVisit) {
        document.querySelectorAll('.policy-card[data-date]').forEach(card => {
          const date = (card as HTMLElement).dataset.date || '';
          if (date > lastVisit.slice(0, 10)) {
            const meta = card.querySelector('.policy-meta');
            if (meta) {
              const badge = document.createElement('span');
              badge.className = 'new-badge';
              badge.textContent = 'NEW';
              meta.insertBefore(badge, meta.firstChild);
            }
          }
        });
      }
      localStorage.setItem('pd-last-visit', now);
    });
  </script>
</body>
</html>
