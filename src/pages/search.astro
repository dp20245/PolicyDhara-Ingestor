---
import Base from '../layouts/Base.astro';
import { getAllPolicies, getMeta } from '../lib/data';

const policies = getAllPolicies();
const meta = getMeta();

const sectors = Object.entries(meta.sector_counts).sort(([,a], [,b]) => b - a).map(([s]) => s);
const sources = Object.entries(meta.source_counts).sort(([,a], [,b]) => b - a).map(([s]) => s);
const types = [...new Set(policies.map(p => p.type))].sort();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

// Build a lightweight search index at build time
const searchIndex = policies.map(p => ({
  id: p.id,
  t: p.title,
  d: p.description,
  dt: p.date,
  src: p.source_short,
  sec: p.sectors,
  ty: p.type,
  lk: p.link,
}));
---
<Base title="Search Policies" description="Search across all tracked Indian development policies by keyword, sector, source, and date.">
  <div style="padding: var(--space-xl) 0;">
    <h2 class="page-title">Search Policies</h2>
    <p class="page-subtitle">Search across {policies.length} policies from {sources.length} sources and {sectors.length} sectors</p>

    <div class="search-box">
      <div class="search-input-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="search-input" class="search-input" placeholder="Search by keyword, policy name, ministry..." autofocus />
        <kbd class="search-kbd">/</kbd>
      </div>

      <div class="search-filters">
        <select id="filter-sector" class="search-select">
          <option value="">All Sectors</option>
          {sectors.map(s => <option value={s}>{s}</option>)}
        </select>
        <select id="filter-source" class="search-select">
          <option value="">All Sources</option>
          {sources.map(s => <option value={s}>{s}</option>)}
        </select>
        <select id="filter-type" class="search-select">
          <option value="">All Types</option>
          {types.map(t => <option value={t}>{t}</option>)}
        </select>
        <input type="date" id="filter-from" class="search-select" title="From date" />
        <input type="date" id="filter-to" class="search-select" title="To date" />
      </div>
    </div>

    <div class="search-meta" id="search-meta">
      <span class="search-mode-toggle">
        <button class="search-mode-btn active" data-mode="fast" type="button" title="In-memory substring search across titles and descriptions">Fast filter</button>
        <button class="search-mode-btn" data-mode="full" type="button" title="Full-text search across the entire policy detail pages, with ranking">Full-text</button>
      </span>
    </div>

    {/* Full-text (Pagefind) results — populated by Pagefind UI when activated */}
    <div id="pagefind-search" style="display:none;"></div>

    <div class="search-results" id="search-results"></div>

    <div class="search-empty" id="search-empty" style="display:none;">
      <h3>No results found</h3>
      <p>Try broadening your search or adjusting filters.</p>
    </div>

    <div class="search-initial" id="search-initial">
      <h3>Start typing to search</h3>
      <p>Search across policy titles, descriptions, and metadata. Use filters to narrow results by sector, source, type, or date range.</p>
      <div class="search-tips">
        <div class="search-tip">
          <strong>Tip:</strong> Press <kbd>/</kbd> anywhere to focus the search box
        </div>
        <div class="search-tip">
          <strong>Examples:</strong> "digital data protection", "education NEP", "PM-KISAN", "semiconductor"
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  .search-box {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-card);
    margin-bottom: var(--space-lg);
  }
  .search-input-wrap {
    position: relative;
    margin-bottom: var(--space-md);
  }
  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: var(--color-text-dim);
  }
  .search-input {
    width: 100%;
    padding: 14px 14px 14px 44px;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg);
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .search-kbd {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 2px 8px;
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }
  .search-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .search-select {
    padding: 8px 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 0.75rem;
    color: var(--color-text);
    background: var(--color-bg);
    cursor: pointer;
  }
  .search-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .search-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    padding: 0 4px;
  }

  /* Results */
  .search-results {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sr-card {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md) var(--space-lg);
    box-shadow: var(--shadow-card);
    transition: border-color 0.15s;
  }
  .sr-card:hover {
    border-color: var(--color-accent);
  }
  .sr-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 6px;
  }
  .sr-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
  }
  .sr-title a {
    color: inherit;
    text-decoration: none;
  }
  .sr-title a:hover {
    color: var(--color-accent);
  }
  .sr-date {
    font-size: 0.6875rem;
    color: var(--color-text-dim);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .sr-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 8px;
  }
  .sr-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    align-items: center;
  }
  .sr-tag {
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }
  .sr-type {
    background: var(--type-announcement-bg);
    color: var(--type-announcement);
  }
  .sr-source {
    background: var(--type-research-bg);
    color: var(--type-research);
  }
  mark {
    background: var(--type-notification-bg);
    color: var(--color-text);
    border-radius: 2px;
    padding: 0 1px;
  }

  /* Empty / Initial */
  .search-empty, .search-initial {
    text-align: center;
    padding: var(--space-xl);
    color: var(--color-text-muted);
  }
  .search-empty h3, .search-initial h3 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.125rem;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  .search-empty p, .search-initial p {
    font-size: 0.8125rem;
  }
  .search-tips {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .search-tip {
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }
  .search-tip kbd {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1px 6px;
    font-family: monospace;
    font-size: 0.6875rem;
  }

  @media (max-width: 768px) {
    .search-filters { flex-direction: column; }
    .search-select { width: 100%; }
    .sr-top { flex-direction: column; gap: 4px; }
  }

  /* Search-mode toggle */
  .search-mode-toggle {
    display: inline-flex;
    gap: 0;
    margin-left: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    overflow: hidden;
  }
  .search-mode-btn {
    padding: 4px 10px;
    background: transparent;
    border: none;
    font: inherit;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .search-mode-btn:hover { background: var(--color-bg-alt); }
  .search-mode-btn.active {
    background: var(--color-accent);
    color: white;
  }
  #search-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }
</style>

{/* Pagefind UI styles + script (loaded only on the search page) */}
<link rel="stylesheet" href={`${base}_pagefind/pagefind-ui.css`} />

<script define:vars={{ base }}>
  // Lazy-init Pagefind UI on first switch to full-text mode
  let pagefindInitialized = false;
  async function initPagefind() {
    if (pagefindInitialized) return;
    pagefindInitialized = true;
    try {
      // @ts-ignore - dynamic import of static asset
      const mod = await import(`${base}_pagefind/pagefind-ui.js`);
      const PagefindUI = mod.PagefindUI || mod.default?.PagefindUI || window.PagefindUI;
      if (!PagefindUI) {
        // Fallback: load via <script> tag
        await new Promise((resolve, reject) => {
          const s = document.createElement('script');
          s.src = `${base}_pagefind/pagefind-ui.js`;
          s.onload = resolve;
          s.onerror = reject;
          document.head.appendChild(s);
        });
      }
      const Ctor = window.PagefindUI || PagefindUI;
      if (Ctor) {
        new Ctor({
          element: '#pagefind-search',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          translations: { placeholder: 'Search the full-text of every policy…' },
        });
      }
    } catch (err) {
      console.warn('Pagefind UI failed to load — falling back to fast filter', err);
      const pf = document.getElementById('pagefind-search');
      if (pf) pf.innerHTML = '<p style="padding: var(--space-md); color: var(--color-text-muted); font-size: 0.8125rem;">Full-text search unavailable. Using fast filter.</p>';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const fastEl = document.getElementById('search-results');
    const fullEl = document.getElementById('pagefind-search');
    const initialEl = document.getElementById('search-initial');
    const emptyEl = document.getElementById('search-empty');
    const buttons = document.querySelectorAll('.search-mode-btn');
    const fastFilters = document.querySelector('.search-filters');

    function setMode(mode) {
      buttons.forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
      if (mode === 'full') {
        if (fastEl) fastEl.style.display = 'none';
        if (initialEl) initialEl.style.display = 'none';
        if (emptyEl) emptyEl.style.display = 'none';
        if (fastFilters) fastFilters.style.opacity = '0.4';
        if (fullEl) fullEl.style.display = '';
        initPagefind();
      } else {
        if (fastEl) fastEl.style.display = '';
        if (fullEl) fullEl.style.display = 'none';
        if (fastFilters) fastFilters.style.opacity = '1';
      }
    }

    buttons.forEach(b => b.addEventListener('click', () => setMode(b.dataset.mode)));
  });
</script>

<script define:vars={{ searchIndex, base }}>
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('search-input');
    const sectorFilter = document.getElementById('filter-sector');
    const sourceFilter = document.getElementById('filter-source');
    const typeFilter = document.getElementById('filter-type');
    const fromFilter = document.getElementById('filter-from');
    const toFilter = document.getElementById('filter-to');
    const resultsEl = document.getElementById('search-results');
    const metaEl = document.getElementById('search-meta');
    const emptyEl = document.getElementById('search-empty');
    const initialEl = document.getElementById('search-initial');
    const kbdEl = document.querySelector('.search-kbd');

    // Press / to focus search
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== input) {
        e.preventDefault();
        input.focus();
      }
      if (e.key === 'Escape' && document.activeElement === input) {
        input.blur();
      }
    });

    // Hide kbd when focused
    input.addEventListener('focus', () => { if (kbdEl) kbdEl.style.display = 'none'; });
    input.addEventListener('blur', () => { if (kbdEl && !input.value) kbdEl.style.display = ''; });

    let timer;
    function onInputChange() {
      clearTimeout(timer);
      timer = setTimeout(() => { runSearch(); syncUrl(); }, 150);
    }

    input.addEventListener('input', onInputChange);
    sectorFilter.addEventListener('change', onInputChange);
    sourceFilter.addEventListener('change', onInputChange);
    typeFilter.addEventListener('change', onInputChange);
    fromFilter.addEventListener('change', onInputChange);
    toFilter.addEventListener('change', onInputChange);

    // ── URL <-> filter state sync ──
    function syncUrl() {
      const params = new URLSearchParams();
      if (input.value.trim()) params.set('q', input.value.trim());
      if (sectorFilter.value) params.set('sector', sectorFilter.value);
      if (sourceFilter.value) params.set('source', sourceFilter.value);
      if (typeFilter.value) params.set('type', typeFilter.value);
      if (fromFilter.value) params.set('from', fromFilter.value);
      if (toFilter.value) params.set('to', toFilter.value);
      const qs = params.toString();
      const newUrl = qs ? `${location.pathname}?${qs}` : location.pathname;
      history.replaceState(null, '', newUrl);
    }

    function loadFromUrl() {
      const params = new URLSearchParams(location.search);
      const q = params.get('q');
      if (q) input.value = q;
      const setIfPresent = (el, key) => { const v = params.get(key); if (v !== null) el.value = v; };
      setIfPresent(sectorFilter, 'sector');
      setIfPresent(sourceFilter, 'source');
      setIfPresent(typeFilter, 'type');
      setIfPresent(fromFilter, 'from');
      setIfPresent(toFilter, 'to');
      if (q || sectorFilter.value || sourceFilter.value || typeFilter.value || fromFilter.value || toFilter.value) {
        runSearch();
      }
    }

    function escapeHtml(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function highlight(text, terms) {
      if (!terms.length) return escapeHtml(text);
      let result = escapeHtml(text);
      for (const term of terms) {
        const re = new RegExp('(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        result = result.replace(re, '<mark>$1</mark>');
      }
      return result;
    }

    function formatDate(iso) {
      try {
        return new Date(iso).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
      } catch { return iso; }
    }

    function runSearch() {
      const query = input.value.trim().toLowerCase();
      const sector = sectorFilter.value;
      const source = sourceFilter.value;
      const type = typeFilter.value;
      const from = fromFilter.value;
      const to = toFilter.value;

      const hasAnyFilter = query || sector || source || type || from || to;

      if (!hasAnyFilter) {
        resultsEl.innerHTML = '';
        metaEl.textContent = '';
        emptyEl.style.display = 'none';
        initialEl.style.display = '';
        return;
      }

      initialEl.style.display = 'none';

      const terms = query ? query.split(/\s+/).filter(t => t.length > 1) : [];

      const results = searchIndex.filter(p => {
        // Text match
        if (terms.length > 0) {
          const haystack = ((p.t || '') + ' ' + (p.d || '') + ' ' + (p.sec || []).join(' ') + ' ' + (p.src || '') + ' ' + (p.ty || '')).toLowerCase();
          if (!terms.every(t => haystack.includes(t))) return false;
        }
        // Filters
        if (sector && !p.sec.includes(sector)) return false;
        if (source && p.src !== source) return false;
        if (type && p.ty !== type) return false;
        if (from && p.dt < from) return false;
        if (to && p.dt > to) return false;
        return true;
      });

      metaEl.textContent = `${results.length} result${results.length !== 1 ? 's' : ''} found` +
        (query ? ` for "${input.value.trim()}"` : '') +
        (sector ? ` in ${sector}` : '') +
        (source ? ` from ${source}` : '');

      if (results.length === 0) {
        resultsEl.innerHTML = '';
        emptyEl.style.display = '';
        return;
      }

      emptyEl.style.display = 'none';

      const shown = results.slice(0, 50);
      resultsEl.innerHTML = shown.map(p => `
        <div class="sr-card">
          <div class="sr-top">
            <div class="sr-title"><a href="${base}policies/${p.id}/">${highlight(p.t, terms)}</a></div>
            <span class="sr-date">${formatDate(p.dt)}</span>
          </div>
          <div class="sr-desc">${highlight((p.d || '').length > 200 ? (p.d || '').slice(0, 200) + '...' : (p.d || ''), terms)}</div>
          <div class="sr-tags">
            <span class="sr-tag sr-type">${escapeHtml(p.ty)}</span>
            <span class="sr-tag sr-source">${escapeHtml(p.src)}</span>
            ${p.sec.slice(0, 3).map(s => `<span class="sr-tag">${escapeHtml(s)}</span>`).join('')}
          </div>
        </div>
      `).join('') + (results.length > 50 ? `<div class="search-meta" style="text-align:center; padding: var(--space-md);">Showing 50 of ${results.length} results. Narrow your search to see more.</div>` : '');
    }

    // Initialize from URL (enables shareable searches and JSON-LD SearchAction)
    loadFromUrl();
  });
</script>
