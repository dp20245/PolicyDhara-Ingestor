---
import Base from '../layouts/Base.astro';
import StatsBar from '../components/StatsBar.astro';
import PolicyTimeline from '../components/PolicyTimeline.astro';
import Insights from '../components/Insights.astro';
import SectorMomentum from '../components/SectorMomentum.astro';
import Sidebar from '../components/Sidebar.astro';
import PolicyCard from '../components/PolicyCard.astro';
import TrendingStrip from '../components/TrendingStrip.astro';
import TrendChart from '../components/TrendChart.astro';
import NewsletterBar from '../components/NewsletterBar.astro';
import { getAllPolicies, getMeta } from '../lib/data';

const allPolicies = getAllPolicies();
const meta = getMeta();
const INITIAL_SHOW = 20;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

// Rotate lead story among top candidates so each build features a different policy
const LEAD_POOL = 10;
const buildDay = Math.floor(Date.now() / 86400000); // changes daily
const leadIdx = buildDay % Math.min(LEAD_POOL, allPolicies.length);
// Move the featured policy to position 0, keep the rest in order
const policies = [...allPolicies];
if (leadIdx > 0 && leadIdx < policies.length) {
  const [featured] = policies.splice(leadIdx, 1);
  policies.unshift(featured);
}

// Compute live stats. Use `first_seen` (ingestion date) for "added this week"
// rather than `date` (issuance date), because most sources don't expose a
// real publication date so `date` is empty for ~half the dataset.
const now = Date.now();
const DAY = 86400000;
const last7d = policies.filter(p => {
  const ref = p.first_seen || p.date;
  if (!ref) return false;
  const t = new Date(ref).getTime();
  return !Number.isNaN(t) && now - t < 7 * DAY;
}).length;

const weekStatNum: number = last7d;
const weekStatLabel: string = 'added this week';
---
<Base title="Dashboard">

  {/* ── Compact Hero ─────────────────────────────────── */}
  <div class="dash-hero">
    <div class="dash-hero-left">
      <h1 class="dash-title">PolicyDhara</h1>
      <p class="dash-subtitle">Tracking Indian development policy — from gazette to ground</p>
      <p class="dash-intro">An open-source platform by <a href="https://www.impactmojo.in">ImpactMojo</a> that aggregates legislation, government schemes, budget announcements, and policy research from official sources into a single searchable database.</p>
    </div>
    <div class="dash-hero-stats">
      <div class="dash-stat">
        <span class="dash-stat-num">{meta.total_policies.toLocaleString()}</span>
        <span class="dash-stat-label">policies</span>
      </div>
      <div class="dash-stat-divider"></div>
      <div class="dash-stat">
        <span class="dash-stat-num">{meta.total_sources}</span>
        <span class="dash-stat-label">sources</span>
      </div>
      <div class="dash-stat-divider"></div>
      <div class="dash-stat">
        <span class="dash-stat-num">{meta.total_sectors}</span>
        <span class="dash-stat-label">sectors</span>
      </div>
      <div class="dash-stat-divider"></div>
      <div class="dash-stat">
        <span class="dash-stat-num">{weekStatNum}</span>
        <span class="dash-stat-label">{weekStatLabel}</span>
      </div>
    </div>
  </div>

  {/* ── Trending ── */}
  <TrendingStrip />

  {/* ── Main Content: Two Column ── */}
  <div class="dash-grid">

    {/* ── Left: Lead Story + Recent ── */}
    <div class="dash-main">
      {policies.length > 0 && (
        <>
          {/* Lead story */}
          <article class="lead-card" data-type={policies[0].type}>
            <div class="lead-accent"></div>
            <div class="lead-body">
              <div class="lead-meta">
                <span class={`policy-type type-${policies[0].type}`}>{policies[0].type}</span>
                <span class="lead-source">{policies[0].source_short}</span>
                <span class="lead-date">{new Date(policies[0].date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
              </div>
              <h2 class="lead-title">
                <a href={`${base}policies/${policies[0].id}/`}>{policies[0].title}</a>
              </h2>
              {policies[0].description && (
                <p class="lead-desc">{policies[0].description}</p>
              )}
              <div class="policy-sectors">
                {policies[0].sectors.map(s => (
                  <a href={`${base}sectors/${s.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-')}/`} class="sector-badge">{s}</a>
                ))}
              </div>
            </div>
          </article>

          {/* Next 5 as compact cards */}
          <div class="recent-grid">
            {policies.slice(1, 7).map(p => (
              <PolicyCard id={p.id} title={p.title} description={p.description} link={p.link}
                date={p.date} source_short={p.source_short} sectors={p.sectors} type={p.type} />
            ))}
          </div>

          <div style="text-align:center; padding: var(--space-sm) 0 var(--space-lg);">
            <button class="btn btn-secondary" id="goto-browse">View All {meta.total_policies} Policies &rarr;</button>
          </div>
        </>
      )}

      {/* Analytics */}
      <div class="section-header">
        <h3>Activity</h3>
      </div>
      <PolicyTimeline />
      <TrendChart />
      <SectorMomentum />
      <Insights />
      <NewsletterBar />
    </div>

    {/* ── Right: Sidebar summary ── */}
    <aside class="dash-sidebar">
      <div class="sidebar-card">
        <h4 class="sidebar-card-title">By Sector</h4>
        <div class="sidebar-sector-list">
          {Object.entries(meta.sector_counts)
            .sort((a, b) => b[1] - a[1])
            .slice(0, 12)
            .map(([sector, count]) => (
              <a href={`${base}sectors/${sector.toLowerCase().replace(/ & /g, '-').replace(/ /g, '-')}/`} class="sidebar-sector-row">
                <span class="sidebar-sector-name">{sector}</span>
                <span class="sidebar-sector-count">{count}</span>
              </a>
            ))
          }
          <a href={`${base}sectors/`} class="sidebar-more">All sectors &rarr;</a>
        </div>
      </div>

      <div class="sidebar-card">
        <h4 class="sidebar-card-title">Quick Links</h4>
        <div class="sidebar-links">
          <a href={`${base}digest/`}>Today's Digest</a>
          <a href={`${base}parliament/`}>Parliament Tracker</a>
          <a href={`${base}budget/`}>Budget Analysis</a>
          <a href={`${base}landscape/`}>Policy Landscape</a>
          <a href={`${base}compare/`}>State Comparison</a>
          <a href={`${base}graph/`}>Policy Graph</a>
          <a href={`${base}api/`}>API Access</a>
        </div>
      </div>

      <div class="sidebar-card sidebar-card-muted">
        <p class="sidebar-meta">
          Data from <strong>{meta.total_sources}</strong> government, media &amp; research sources.
          Updated every 6 hours. <a href={`${base}about/`}>Methodology</a>
        </p>
      </div>
    </aside>
  </div>

  {/* ── Browse Tab (hidden by default, shown on click) ── */}
  <div id="browse-panel" style="display:none;">
    <div class="page-grid">
      <Sidebar
        sectorCounts={meta.sector_counts}
        sourceCounts={meta.source_counts}
      />
      <section>
        <div class="feed-toolbar">
          <div id="feed-status" aria-live="polite" style="font-size:0.75rem; color:var(--color-text-muted);"></div>
          <div class="feed-toolbar-actions">
            <button class="btn btn-secondary btn-sm" id="export-csv" title="Export visible policies as CSV">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              CSV
            </button>
            <button class="btn btn-secondary btn-sm" id="export-json" title="Export visible policies as JSON">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              JSON
            </button>
          </div>
        </div>
        <div class="policy-feed" id="policy-feed">
          {policies.length === 0 ? (
            <div class="empty-state">
              <h3>No policies fetched yet</h3>
              <p>Run the pipeline or wait for the next GitHub Actions run.</p>
            </div>
          ) : (
            policies.map((p, i) => (
              <div class={`policy-card-wrap ${i >= INITIAL_SHOW ? 'hidden-card' : ''}`}>
                <PolicyCard id={p.id} title={p.title} description={p.description} link={p.link}
                  date={p.date} source_short={p.source_short} sectors={p.sectors} type={p.type} />
              </div>
            ))
          )}
          {policies.length > INITIAL_SHOW && (
            <div class="show-more-wrap" id="show-more-wrap">
              <button class="btn btn-primary" id="show-more-btn">
                Show More <span id="remaining-count">({policies.length - INITIAL_SHOW} more)</span>
              </button>
            </div>
          )}
        </div>
        <div id="no-results" class="empty-state" style="display:none;">
          <h3>No matching policies</h3>
          <p>Try adjusting your search or filters.</p>
        </div>
      </section>
    </div>
  </div>

</Base>

<style>
  /* ── Dashboard Hero ───────────────────────────────── */
  .dash-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }
  .dash-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-text);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .dash-subtitle {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-top: 4px;
  }
  .dash-intro {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-top: 8px;
    max-width: 520px;
  }
  .dash-intro a {
    color: var(--color-accent);
    font-weight: 600;
  }
  .dash-hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-shrink: 0;
  }
  .dash-stat {
    text-align: center;
  }
  .dash-stat-num {
    display: block;
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }
  .dash-stat-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .dash-stat-divider {
    width: 1px;
    height: 32px;
    background: var(--color-border);
  }

  @media (max-width: 768px) {
    .dash-hero { flex-direction: column; align-items: flex-start; }
    .dash-hero-stats { gap: var(--space-lg); }
    .dash-title { font-size: 1.5rem; }
  }
  @media (max-width: 480px) {
    .dash-hero-stats { gap: var(--space-sm); }
    .dash-stat-num { font-size: 1.25rem; }
  }

  /* ── Two-column dashboard grid ─────────────────────── */
  .dash-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }
  @media (max-width: 960px) {
    .dash-grid { grid-template-columns: 1fr; }
  }

  /* ── Lead Card ─────────────────────────────────────── */
  .lead-card {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    margin-bottom: var(--space-lg);
    transition: box-shadow 0.2s;
  }
  .lead-card:hover {
    box-shadow: var(--shadow-card-hover);
  }
  .lead-accent {
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--type-legislation) 50%, var(--type-announcement) 100%);
  }
  .lead-body {
    padding: 20px 24px;
  }
  .lead-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    font-size: 0.75rem;
  }
  .lead-source {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
    font-size: 0.6875rem;
  }
  .lead-date {
    color: var(--color-text-muted);
  }
  .lead-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  .lead-title a { color: inherit; text-decoration: none; }
  .lead-title a:hover { color: var(--color-accent); }
  .lead-desc {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 12px;
    max-width: 700px;
  }

  @media (max-width: 600px) {
    .lead-body { padding: 16px; }
    .lead-title { font-size: 1.125rem; }
  }

  /* ── Recent Grid ───────────────────────────────────── */
  .recent-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: var(--space-md);
  }
  @media (max-width: 768px) {
    .recent-grid { grid-template-columns: 1fr; }
  }

  /* ── Sidebar ───────────────────────────────────────── */
  .dash-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .sidebar-card {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    box-shadow: var(--shadow-sm);
  }
  .sidebar-card-muted {
    background: var(--color-bg-alt);
    border-color: var(--color-border-light);
  }
  .sidebar-card-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid var(--color-border-light);
  }
  .sidebar-sector-list {
    display: flex;
    flex-direction: column;
  }
  .sidebar-sector-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 5px 4px;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    border-radius: var(--radius-sm);
    transition: all 0.1s;
    text-decoration: none;
  }
  .sidebar-sector-row:hover {
    background: var(--color-accent-bg);
    color: var(--color-accent);
  }
  .sidebar-sector-name {
    font-weight: 500;
  }
  .sidebar-sector-count {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-dim);
    background: var(--color-bg-alt);
    padding: 1px 7px;
    border-radius: var(--radius-pill);
  }
  .sidebar-more {
    display: block;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 6px 0 2px;
    color: var(--color-accent);
    text-decoration: none;
  }
  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sidebar-links a {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    padding: 5px 4px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.1s;
  }
  .sidebar-links a:hover {
    background: var(--color-accent-bg);
    color: var(--color-accent);
  }
  .sidebar-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  .sidebar-meta strong {
    color: var(--color-text-secondary);
  }

  .section-header {
    margin-bottom: var(--space-lg);
  }
  .section-header h3 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .section-header p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .feed-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
    padding: 8px 12px;
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
  }
  .feed-toolbar-actions {
    display: flex;
    gap: 6px;
  }
  .btn-sm {
    padding: 6px 12px !important;
    font-size: 0.6875rem !important;
    gap: 4px !important;
  }

  .policy-card-wrap { display: contents; }
  .hidden-card > .policy-card { display: none; }
</style>

<script define:vars={{ INITIAL_SHOW }}>
  document.addEventListener('DOMContentLoaded', () => {
    // "View All Policies" button — show browse panel
    const gotoBrowse = document.getElementById('goto-browse');
    const browsePanel = document.getElementById('browse-panel');
    if (gotoBrowse && browsePanel) {
      gotoBrowse.addEventListener('click', () => {
        browsePanel.style.display = '';
        gotoBrowse.style.display = 'none';
        browsePanel.scrollIntoView({ behavior: 'smooth' });
      });
    }

    // ── Feed filtering (Browse panel) ──
    const wraps = Array.from(document.querySelectorAll('.policy-card-wrap'));
    const cards = wraps.map(w => w.querySelector('.policy-card'));
    const searchInput = document.getElementById('policy-search');
    const noResults = document.getElementById('no-results');
    const feedStatus = document.getElementById('feed-status');
    const showMoreBtn = document.getElementById('show-more-btn');
    const showMoreWrap = document.getElementById('show-more-wrap');
    const remainingCount = document.getElementById('remaining-count');

    let showCount = INITIAL_SHOW;
    let activeSector = 'all';
    let activeType = 'all';
    let activeSource = 'all';
    let searchQuery = '';
    let isFiltering = false;

    function applyFilters() {
      let visibleCount = 0;
      let totalMatching = 0;
      isFiltering = activeSector !== 'all' || activeType !== 'all' || activeSource !== 'all' || searchQuery !== '';

      for (let i = 0; i < cards.length; i++) {
        const card = cards[i];
        if (!card) continue;
        const sectors = JSON.parse(card.dataset.sectors || '[]');
        const type = card.dataset.type || '';
        const source = card.dataset.source || '';
        const text = card.textContent?.toLowerCase() || '';

        const matches = (activeSector === 'all' || sectors.includes(activeSector))
          && (activeType === 'all' || type === activeType)
          && (activeSource === 'all' || source === activeSource)
          && (!searchQuery || text.includes(searchQuery.toLowerCase()));

        if (matches) {
          totalMatching++;
          if (isFiltering || totalMatching <= showCount) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        } else {
          card.style.display = 'none';
        }
      }

      if (noResults) noResults.style.display = visibleCount === 0 ? '' : 'none';
      if (feedStatus) feedStatus.textContent = `Showing ${visibleCount} of ${cards.length} policies`;

      if (showMoreWrap) {
        if (isFiltering || showCount >= cards.length) {
          showMoreWrap.style.display = 'none';
        } else {
          const remaining = totalMatching - showCount;
          showMoreWrap.style.display = remaining > 0 ? '' : 'none';
          if (remainingCount && remaining > 0) remainingCount.textContent = `(${remaining} more)`;
        }
      }
    }

    if (showMoreBtn) showMoreBtn.addEventListener('click', () => { showCount += 20; applyFilters(); });

    document.querySelectorAll('.sector-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sector-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeSector = btn.dataset.sector || 'all';
        applyFilters();
      });
    });

    document.querySelectorAll('.type-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.type-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeType = btn.dataset.type || 'all';
        applyFilters();
      });
    });

    document.querySelectorAll('.source-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.source-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeSource = btn.dataset.source || 'all';
        applyFilters();
      });
    });

    if (searchInput) {
      let timer;
      searchInput.addEventListener('input', () => {
        clearTimeout(timer);
        timer = setTimeout(() => { searchQuery = searchInput.value; applyFilters(); }, 200);
      });
    }

    applyFilters();

    // ── Export ──
    function getVisiblePolicies() {
      const visible = [];
      for (let i = 0; i < cards.length; i++) {
        const card = cards[i];
        if (!card || card.style.display === 'none') continue;
        visible.push({
          id: card.dataset.id || '',
          title: card.querySelector('.policy-title')?.textContent?.trim() || '',
          type: card.dataset.type || '',
          source: card.dataset.source || '',
          date: card.dataset.date || '',
          sectors: JSON.parse(card.dataset.sectors || '[]'),
          description: card.querySelector('.policy-description')?.textContent?.trim() || '',
        });
      }
      return visible;
    }

    function downloadFile(content, filename, mimeType) {
      const blob = new Blob([content], { type: mimeType });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    }

    document.getElementById('export-csv')?.addEventListener('click', () => {
      const rows = getVisiblePolicies();
      if (rows.length === 0) return;
      const headers = ['id', 'title', 'type', 'source', 'date', 'sectors', 'description'];
      const csv = [headers.join(',')].concat(
        rows.map(r => headers.map(h => {
          let v = h === 'sectors' ? r[h].join('; ') : r[h];
          return '"' + String(v).replace(/"/g, '""') + '"';
        }).join(','))
      ).join('\n');
      downloadFile(csv, `policydhara-export-${new Date().toISOString().slice(0,10)}.csv`, 'text/csv');
    });

    document.getElementById('export-json')?.addEventListener('click', () => {
      const rows = getVisiblePolicies();
      if (rows.length === 0) return;
      downloadFile(JSON.stringify(rows, null, 2), `policydhara-export-${new Date().toISOString().slice(0,10)}.json`, 'application/json');
    });
  });
</script>
