---
import { getAllPolicies, getMeta } from '../../lib/data';

const meta = getMeta();
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const siteUrl = `https://varnasr.github.io${base}`;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PolicyDhara Stats</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #ffffff;
      color: #1a1a2e;
      overflow: hidden;
    }
    .badge {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 16px;
      background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      height: 72px;
    }
    .badge-icon {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      background: #2563eb;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .badge-icon svg {
      width: 20px;
      height: 20px;
    }
    .badge-content {
      flex: 1;
      min-width: 0;
    }
    .badge-title {
      font-size: 11px;
      font-weight: 700;
      color: #2563eb;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 2px;
    }
    .badge-stats {
      display: flex;
      gap: 16px;
      align-items: baseline;
    }
    .badge-stat {
      display: flex;
      align-items: baseline;
      gap: 4px;
    }
    .badge-num {
      font-size: 20px;
      font-weight: 800;
      color: #1a1a2e;
      line-height: 1;
    }
    .badge-label {
      font-size: 10px;
      color: #64748b;
      font-weight: 500;
    }
    .badge-link {
      display: flex;
      align-items: center;
      gap: 3px;
      font-size: 9px;
      color: #94a3b8;
      text-decoration: none;
      margin-top: 2px;
      font-weight: 500;
    }
    .badge-link:hover {
      color: #2563eb;
    }
    .badge-sep {
      width: 1px;
      height: 24px;
      background: #e2e8f0;
      flex-shrink: 0;
    }
  </style>
</head>
<body>
  <div class="badge">
    <div class="badge-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
    </div>
    <div class="badge-content">
      <div class="badge-stats">
        <div class="badge-stat">
          <span class="badge-num">{meta.total_policies}</span>
          <span class="badge-label">policies</span>
        </div>
        <div class="badge-sep"></div>
        <div class="badge-stat">
          <span class="badge-num">{meta.total_sources}</span>
          <span class="badge-label">sources</span>
        </div>
        <div class="badge-sep"></div>
        <div class="badge-stat">
          <span class="badge-num">{Object.keys(meta.sector_counts).length}</span>
          <span class="badge-label">sectors</span>
        </div>
      </div>
      <a class="badge-link" href={siteUrl} target="_blank" rel="noopener">
        Powered by PolicyDhara
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
      </a>
    </div>
  </div>
</body>
</html>
