---
import { getAllPolicies, getMeta, getPoliciesBySector, getSectorSlug } from '../../lib/data';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const siteUrl = `https://varnasr.github.io${base}`;

// Read URL params
const url = new URL(Astro.request.url);
const sectorParam = url.searchParams.get('sector') || '';
const limitParam = parseInt(url.searchParams.get('limit') || '5', 10);
const limit = Math.max(1, Math.min(limitParam, 20));

// Get policies
const meta = getMeta();
let policies;
let sectorDisplayName = '';

if (sectorParam) {
  // Find the display name for the sector slug
  const sectorEntries = Object.keys(meta.sector_counts);
  const matchedSector = sectorEntries.find(s => getSectorSlug(s) === sectorParam);
  if (matchedSector) {
    sectorDisplayName = matchedSector;
    policies = getPoliciesBySector(sectorParam).slice(0, limit);
  } else {
    policies = getAllPolicies().slice(0, limit);
  }
} else {
  policies = getAllPolicies().slice(0, limit);
}

const heading = sectorDisplayName ? `${sectorDisplayName} Policies` : 'Recent Policies';

// Sector colors for badges
const sectorColors: Record<string, string> = {
  'Health': '#059669',
  'Education': '#7c3aed',
  'Finance & Economy': '#d97706',
  'Digital & Technology': '#2563eb',
  'Agriculture': '#16a34a',
  'Climate & Environment': '#0d9488',
  'Defence & Security': '#dc2626',
  'Governance & Reform': '#6366f1',
  'Energy': '#ea580c',
  'Social Protection': '#db2777',
  'Labour & Employment': '#9333ea',
  'Rural Development': '#65a30d',
  'Water & Sanitation': '#0891b2',
  'Infrastructure': '#78716c',
  'Trade & Commerce': '#ca8a04',
  'Science & Innovation': '#4f46e5',
  'Gender & Women': '#e11d48',
  'Transport': '#0284c7',
  'Housing & Urban': '#8b5cf6',
  'Civil Liberties': '#b91c1c',
};

function getColor(sector: string): string {
  return sectorColors[sector] || '#64748b';
}
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PolicyDhara Feed{sectorDisplayName ? ` - ${sectorDisplayName}` : ''}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #ffffff;
      color: #1a1a2e;
      overflow-x: hidden;
    }
    .feed {
      padding: 12px 14px;
    }
    .feed-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
      padding-bottom: 8px;
      border-bottom: 2px solid #eef2ff;
    }
    .feed-title {
      font-size: 12px;
      font-weight: 700;
      color: #1a1a2e;
    }
    .feed-count {
      font-size: 10px;
      color: #94a3b8;
      font-weight: 500;
    }
    .feed-item {
      padding: 8px 0;
      border-bottom: 1px solid #f1f5f9;
    }
    .feed-item:last-of-type {
      border-bottom: none;
    }
    .feed-item-title {
      font-size: 11.5px;
      font-weight: 600;
      color: #1a1a2e;
      line-height: 1.4;
      margin-bottom: 4px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .feed-item-title a {
      color: inherit;
      text-decoration: none;
    }
    .feed-item-title a:hover {
      color: #2563eb;
    }
    .feed-item-meta {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
    }
    .feed-item-date {
      font-size: 10px;
      color: #94a3b8;
      font-weight: 500;
    }
    .feed-sector-badge {
      font-size: 9px;
      padding: 1px 6px;
      border-radius: 10px;
      font-weight: 600;
      color: #fff;
      white-space: nowrap;
    }
    .feed-type {
      font-size: 9px;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 600;
    }
    .feed-footer {
      margin-top: 10px;
      padding-top: 8px;
      border-top: 2px solid #eef2ff;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .feed-more {
      font-size: 10px;
      color: #2563eb;
      text-decoration: none;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 3px;
    }
    .feed-more:hover {
      text-decoration: underline;
    }
    .feed-powered {
      font-size: 9px;
      color: #cbd5e1;
      text-decoration: none;
    }
    .feed-powered:hover {
      color: #2563eb;
    }
    .feed-empty {
      text-align: center;
      padding: 24px 0;
      font-size: 12px;
      color: #94a3b8;
    }
  </style>
</head>
<body>
  <div class="feed">
    <div class="feed-header">
      <span class="feed-title">{heading}</span>
      <span class="feed-count">{policies.length} of {sectorDisplayName ? getPoliciesBySector(sectorParam).length : meta.total_policies}</span>
    </div>

    {policies.length === 0 ? (
      <div class="feed-empty">No policies found for this sector.</div>
    ) : (
      policies.map(p => {
        const dateStr = new Date(p.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
        return (
          <div class="feed-item">
            <div class="feed-item-title">
              <a href={p.link} target="_blank" rel="noopener">{p.title}</a>
            </div>
            <div class="feed-item-meta">
              <span class="feed-item-date">{dateStr}</span>
              {p.sectors.slice(0, 2).map(s => (
                <span class="feed-sector-badge" style={`background:${getColor(s)}`}>{s}</span>
              ))}
              <span class="feed-type">{p.type}</span>
            </div>
          </div>
        );
      })
    )}

    <div class="feed-footer">
      <a class="feed-more" href={sectorDisplayName ? `${siteUrl}sectors/${sectorParam}/` : `${siteUrl}search/`} target="_blank" rel="noopener">
        View more on PolicyDhara
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
      </a>
      <a class="feed-powered" href={siteUrl} target="_blank" rel="noopener">Powered by PolicyDhara</a>
    </div>
  </div>
</body>
</html>
