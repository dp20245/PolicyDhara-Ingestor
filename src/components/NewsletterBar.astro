---
---
<div class="newsletter-bar">
  <div class="newsletter-text">
    <h4>PolicyDhara Daily Brief</h4>
    <p>Get the day's policy actions delivered to your inbox every morning.</p>
  </div>
  <div class="newsletter-actions">
    <form class="newsletter-form" id="newsletter-form" action="https://buttondown.com/api/emails/embed-subscribe/policydhara" method="post" target="popupwindow">
      <input type="email" name="email" class="newsletter-input" placeholder="your@email.com" required id="newsletter-email" />
      <button type="submit" class="newsletter-submit" id="newsletter-btn">Subscribe</button>
    </form>
    <div class="newsletter-divider"><span>or</span></div>
    <a class="newsletter-telegram" href="https://t.me/policydhara" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path d="M22.05 2.79 2.34 10.4c-1.34.54-1.33 1.29-.24 1.62l5.06 1.58 11.71-7.39c.55-.34 1.06-.16.64.21l-9.48 8.56h-.01l.01.01-.35 5.22c.5 0 .72-.23.99-.5l2.39-2.33 4.97 3.67c.92.5 1.58.24 1.81-.85l3.27-15.42c.34-1.33-.51-1.94-1.36-1.6Z"/>
      </svg>
      <span>Get instant alerts on Telegram</span>
    </a>
  </div>
</div>

<style>
  .newsletter-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: stretch;
  }
  .newsletter-divider {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .newsletter-divider::before,
  .newsletter-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border-light);
  }
  .newsletter-telegram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 9px 14px;
    background: linear-gradient(135deg, #229ED9 0%, #2AABEE 100%);
    color: #fff;
    border-radius: var(--radius-md);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(34, 158, 217, 0.25);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .newsletter-telegram:hover {
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(34, 158, 217, 0.35);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('newsletter-form') as HTMLFormElement;
    const btn = document.getElementById('newsletter-btn') as HTMLButtonElement;
    const input = document.getElementById('newsletter-email') as HTMLInputElement;

    if (form) {
      form.addEventListener('submit', () => {
        // Buttondown handles the actual subscription via form action.
        // We just update the UI optimistically.
        setTimeout(() => {
          if (btn && input) {
            btn.textContent = 'Subscribed!';
            btn.style.background = '#16a34a';
            input.disabled = true;
            btn.disabled = true;
            localStorage.setItem('pd-newsletter-sub', input.value);
          }
        }, 300);
      });

      // Check if already subscribed
      const sub = localStorage.getItem('pd-newsletter-sub');
      if (sub && btn && input) {
        btn.textContent = 'Subscribed';
        btn.style.background = '#16a34a';
        input.value = sub;
        input.disabled = true;
        btn.disabled = true;
      }
    }
  });
</script>
