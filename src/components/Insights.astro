---
import { getTypeDistribution, getTopSectors, getWeeklyTrends, getMeta, getAllPolicies, getSectorSlug, getEraDistribution, getStateGovernments } from '../lib/data';
import type { PolicyItem } from '../lib/data';

const typeDist = getTypeDistribution();
const topSectors = getTopSectors(8);
const weeklyTrends = getWeeklyTrends();
const eraDist = getEraDistribution();
const meta = getMeta();
const policies = getAllPolicies();
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

// Era bar widths
const maxEraCount = Math.max(...eraDist.map(e => e.count), 1);
const ERA_COLORS: Record<string, string> = {
  'UPA I': '#f97316', 'UPA II': '#ea580c',
  'NDA I': '#3b82f6', 'NDA II': '#1d4ed8', 'NDA III': '#2563eb',
};

// Weekly trend sparkline data (last 12 weeks)
const recentWeeks = weeklyTrends.slice(-12);
const maxWeekly = Math.max(...recentWeeks.map(w => w.count), 1);

// Type colors for the bar chart
const TYPE_COLORS: Record<string, string> = {
  legislation: '#dc2626', notification: '#d97706', scheme: '#16a34a',
  budget: '#ea580c', research: '#7c3aed', announcement: '#2563eb', policy: '#9333ea',
};

// Top sector max for bar widths
const maxSectorCount = Math.max(...topSectors.map(s => s.count), 1);

// Recency uses `first_seen` (when PolicyDhara ingested) for "added this week"
// stats — `date` is the policy's issuance date and is empty for ~half the
// dataset where the source didn't expose a publication date. Mixing them
// would make every fetch cycle look like a flood of new policies.
const now = Date.now();
const DAY = 86400000;
function ageDays(p: PolicyItem): number | null {
  const ref = p.first_seen || p.date;
  if (!ref) return null;
  const t = new Date(ref).getTime();
  if (Number.isNaN(t)) return null;
  return (now - t) / DAY;
}
const last7 = policies.filter(p => {
  const a = ageDays(p);
  return a !== null && a < 7;
}).length;
const prev7 = policies.filter(p => {
  const a = ageDays(p);
  return a !== null && a >= 7 && a < 14;
}).length;
// Honest comparison: only show a percentage when both periods have data.
// Otherwise show '—' (no comparable baseline).
const hasComparison = prev7 > 0;
const trendPct = hasComparison ? Math.round(((last7 - prev7) / prev7) * 100) : 0;
const trendUp = trendPct >= 0;

// Count policies with a real (non-empty) issuance date — useful caveat for users
const policiesWithIssuanceDate = policies.filter(p => !!p.date).length;
const issuanceDateCoveragePct = Math.round((policiesWithIssuanceDate / policies.length) * 100);

// State governance summary
const stateGovs = getStateGovernments().filter(g => g.type === 'state');
const govPartyGroups: Record<string, number> = {};
for (const g of stateGovs) {
  const key = g.party.includes('BJP') ? 'BJP/NDA' : g.party.includes('Congress') ? 'Congress/UPA' : 'Others';
  govPartyGroups[key] = (govPartyGroups[key] || 0) + 1;
}
const GOV_PARTY_COLORS: Record<string, string> = {
  'BJP/NDA': '#1d4ed8',
  'Congress/UPA': '#f97316',
  'Others': '#737373',
};
---
<div class="insights-grid">
  {/* Quick stats row */}
  <div class="insight-card insight-quickstats">
    <h4>Added This Week</h4>
    <div class="qs-row">
      <div class="qs-item">
        <span class="qs-number">{last7}</span>
        <span class="qs-label">Policies ingested<br/>(last 7 days)</span>
      </div>
      <div class="qs-item">
        {hasComparison ? (
          <>
            <span class={`qs-trend ${trendUp ? 'trend-up' : 'trend-down'}`}>
              {trendUp ? '\u25B2' : '\u25BC'} {Math.abs(trendPct)}%
            </span>
            <span class="qs-label">vs previous week</span>
          </>
        ) : (
          <>
            <span class="qs-trend trend-neutral">\u2014</span>
            <span class="qs-label">no prior week<br/>to compare</span>
          </>
        )}
      </div>
    </div>
    <p class="qs-note">
      Counts when items were <em>added</em> to PolicyDhara, not when they were
      <em>issued</em>. Only {issuanceDateCoveragePct}% of items expose a
      publication date.
    </p>
  </div>

  {/* Data depth / historical coverage */}
  <div class="insight-card insight-trend">
    <h4>Data Coverage</h4>
    <div class="coverage-stats">
      <div class="coverage-item">
        <span class="coverage-num">{(() => { const dates = policies.map(p => p.date).sort(); return dates[0]?.slice(0, 4) || '—'; })()}</span>
        <span class="coverage-label">Earliest Policy</span>
      </div>
      <div class="coverage-arrow">&rarr;</div>
      <div class="coverage-item">
        <span class="coverage-num">{(() => { const dates = policies.map(p => p.date).sort(); return dates[dates.length - 1]?.slice(0, 4) || '—'; })()}</span>
        <span class="coverage-label">Latest Policy</span>
      </div>
    </div>
    <div class="coverage-eras">
      {eraDist.filter(e => e.count > 0).map(e => (
        <div class="coverage-era-row">
          <span class="coverage-era-name" style={`color: ${ERA_COLORS[e.era] || '#888'};`}>{e.era}</span>
          <span class="coverage-era-count">{e.count}</span>
        </div>
      ))}
    </div>
    <div class="coverage-note">
      Coverage is uneven — recent eras have better digital archival than earlier eras
    </div>
  </div>

  {/* Type distribution */}
  <div class="insight-card insight-types">
    <h4>Policy Types</h4>
    <div class="type-bars">
      {typeDist.map(t => (
        <div class="type-bar-row">
          <span class="type-bar-label">{t.type}</span>
          <div class="type-bar-track">
            <div class="type-bar-fill" style={`width: ${t.pct}%; background: ${TYPE_COLORS[t.type] || '#888'};`}></div>
          </div>
          <span class="type-bar-count">{t.count}</span>
        </div>
      ))}
    </div>
  </div>

  {/* Top sectors */}
  <div class="insight-card insight-sectors">
    <h4>Top Sectors</h4>
    <div class="sector-bars">
      {topSectors.map(s => (
        <a href={`${base}sectors/${s.slug}/`} class="sector-bar-row">
          <span class="sector-bar-label">{s.sector}</span>
          <div class="sector-bar-track">
            <div class="sector-bar-fill" style={`width: ${(s.count / maxSectorCount) * 100}%;`}></div>
          </div>
          <span class="sector-bar-count">{s.count}</span>
        </a>
      ))}
    </div>
  </div>

  {/* Government era distribution */}
  {eraDist.some(e => e.count > 0) && (
    <div class="insight-card insight-eras">
      <h4>Policy by Government Era</h4>
      <div class="era-bars">
        {eraDist.map(e => (
          <div class="era-bar-row">
            <div class="era-bar-meta">
              <span class="era-bar-name">{e.era}</span>
              <span class="era-bar-party">{e.party}</span>
            </div>
            <div class="era-bar-track">
              <div class="era-bar-fill" style={`width: ${(e.count / maxEraCount) * 100}%; background: ${ERA_COLORS[e.era] || '#888'};`}></div>
            </div>
            <span class="era-bar-count">{e.count}</span>
          </div>
        ))}
      </div>
      <div class="era-legend">
        <span class="era-legend-item"><span class="era-dot" style="background:#f97316;"></span>UPA (Congress-led)</span>
        <span class="era-legend-item"><span class="era-dot" style="background:#2563eb;"></span>NDA (BJP-led)</span>
      </div>
      <div class="era-caveat">
        Counts reflect digital archive availability, not actual policy volume. Earlier eras are underrepresented.
      </div>
    </div>
  )}

  {/* State governance overview */}
  <div class="insight-card insight-governance">
    <h4><a href={`${base}states/`} class="insight-link">State Governance</a></h4>
    <div class="gov-bars">
      {Object.entries(govPartyGroups).sort(([,a], [,b]) => b - a).map(([party, count]) => (
        <div class="gov-bar-row">
          <span class="gov-bar-label">{party}</span>
          <div class="gov-bar-track">
            <div class="gov-bar-fill" style={`width: ${(count / stateGovs.length) * 100}%; background: ${GOV_PARTY_COLORS[party] || '#888'};`}></div>
          </div>
          <span class="gov-bar-count">{count}</span>
        </div>
      ))}
    </div>
    <div class="gov-total">
      <span>{stateGovs.length} states tracked</span>
      <a href={`${base}states/`} class="gov-view-link">View all &rarr;</a>
    </div>
  </div>
</div>

<style>
  .insights-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: var(--space-xl);
  }

  .insight-card {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-card);
  }
  .insight-card h4 {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  /* Quick stats */
  .qs-row { display: flex; gap: var(--space-xl); align-items: center; }
  .qs-item { display: flex; flex-direction: column; gap: 2px; }
  .qs-number {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }
  .qs-label { font-size: 0.6875rem; color: var(--color-text-muted); }
  .qs-trend {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
  }
  .trend-up { color: var(--color-accent); }
  .trend-down { color: #dc2626; }
  .trend-neutral { color: var(--color-text-muted); }
  .qs-note {
    margin: var(--space-xs) 0 0 0;
    padding-top: var(--space-xs);
    border-top: 1px dashed var(--color-border);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
  .qs-note em { font-style: normal; color: var(--color-text); font-weight: 500; }

  /* Data Coverage */
  .coverage-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: var(--space-md);
  }
  .coverage-item { text-align: center; }
  .coverage-num {
    display: block;
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }
  .coverage-label {
    font-size: 0.5625rem;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .coverage-arrow {
    font-size: 1.25rem;
    color: var(--color-text-dim);
  }
  .coverage-eras {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: var(--space-sm);
  }
  .coverage-era-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
  }
  .coverage-era-name { font-weight: 600; }
  .coverage-era-count { font-weight: 700; color: var(--color-text-muted); }
  .coverage-note {
    font-size: 0.625rem;
    color: var(--color-text-dim);
    text-align: center;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border-light);
  }

  /* Type distribution bars */
  .type-bars { display: flex; flex-direction: column; gap: 8px; }
  .type-bar-row { display: flex; align-items: center; gap: 8px; }
  .type-bar-label {
    width: 90px;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-transform: capitalize;
    flex-shrink: 0;
  }
  .type-bar-track {
    flex: 1;
    height: 8px;
    background: var(--color-bg-alt);
    border-radius: 4px;
    overflow: hidden;
  }
  .type-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.3s;
  }
  .type-bar-count {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    font-weight: 600;
    width: 28px;
    text-align: right;
    flex-shrink: 0;
  }

  /* Sector bars */
  .sector-bars { display: flex; flex-direction: column; gap: 8px; }
  .sector-bar-row {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: inherit;
  }
  .sector-bar-row:hover .sector-bar-label { color: var(--color-accent); }
  .sector-bar-row:hover .sector-bar-fill { background: var(--color-accent) !important; }
  .sector-bar-label {
    width: 140px;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    flex-shrink: 0;
    transition: color 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sector-bar-track {
    flex: 1;
    height: 8px;
    background: var(--color-bg-alt);
    border-radius: 4px;
    overflow: hidden;
  }
  .sector-bar-fill {
    height: 100%;
    border-radius: 4px;
    background: #2563eb;
    transition: width 0.3s, background 0.15s;
  }
  .sector-bar-count {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    font-weight: 600;
    width: 28px;
    text-align: right;
    flex-shrink: 0;
  }

  /* Government era bars */
  .era-bars { display: flex; flex-direction: column; gap: 10px; }
  .era-bar-row { display: flex; align-items: center; gap: 8px; }
  .era-bar-meta {
    width: 130px; flex-shrink: 0;
    display: flex; flex-direction: column; gap: 1px;
  }
  .era-bar-name { font-size: 0.8125rem; font-weight: 600; color: var(--color-text); }
  .era-bar-party { font-size: 0.5625rem; color: var(--color-text-dim); }
  .era-bar-track {
    flex: 1; height: 10px;
    background: var(--color-bg-alt); border-radius: 5px; overflow: hidden;
  }
  .era-bar-fill { height: 100%; border-radius: 5px; transition: width 0.3s; }
  .era-bar-count {
    font-size: 0.75rem; font-weight: 700;
    color: var(--color-text-muted); width: 28px; text-align: right; flex-shrink: 0;
  }
  .era-legend {
    display: flex; gap: 16px; margin-top: 10px; padding-top: 8px;
    border-top: 1px solid var(--color-border-light);
  }
  .era-legend-item {
    display: flex; align-items: center; gap: 4px;
    font-size: 0.625rem; color: var(--color-text-muted);
  }
  .era-dot { width: 8px; height: 8px; border-radius: 2px; }
  .era-caveat {
    font-size: 0.5625rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-alt);
    border-radius: 3px;
    padding: 4px 8px;
    margin-top: 8px;
    line-height: 1.4;
  }

  /* State governance card */
  .insight-link {
    color: inherit;
    text-decoration: none;
  }
  .insight-link:hover { color: var(--color-accent); }
  .gov-bars { display: flex; flex-direction: column; gap: 8px; }
  .gov-bar-row { display: flex; align-items: center; gap: 8px; }
  .gov-bar-label {
    width: 100px;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }
  .gov-bar-track {
    flex: 1;
    height: 8px;
    background: var(--color-bg-alt);
    border-radius: 4px;
    overflow: hidden;
  }
  .gov-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.3s;
  }
  .gov-bar-count {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    font-weight: 600;
    width: 22px;
    text-align: right;
    flex-shrink: 0;
  }
  .gov-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid var(--color-border-light);
    font-size: 0.625rem;
    color: var(--color-text-dim);
  }
  .gov-view-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.6875rem;
  }
  .gov-view-link:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .insights-grid { grid-template-columns: 1fr; }
    .sector-bar-label { width: 100px; }
    .type-bar-label { width: 70px; }
    .era-bar-meta { width: 90px; }
  }
</style>
