---
import { getWeeklyTrends } from '../lib/data';

const allTrends = getWeeklyTrends();
const trends = allTrends.slice(-12);

// Compute stats
const counts = trends.map(t => t.count);
const maxCount = Math.max(...counts, 1);
const minCount = Math.min(...counts);
const avgCount = counts.reduce((a, b) => a + b, 0) / (counts.length || 1);

// SVG dimensions
const svgWidth = 600;
const svgHeight = 260;
const padTop = 30;
const padBottom = 50;
const padLeft = 40;
const padRight = 20;

const chartW = svgWidth - padLeft - padRight;
const chartH = svgHeight - padTop - padBottom;

const barCount = trends.length;
const barGap = 8;
const barWidth = barCount > 0 ? (chartW - (barCount - 1) * barGap) / barCount : 0;

// Y-axis: nice round max
const yMax = Math.ceil(maxCount * 1.15) || 1;

function yPos(val: number): number {
  return padTop + chartH - (val / yMax) * chartH;
}

function xBar(i: number): number {
  return padLeft + i * (barWidth + barGap);
}

// Reference lines
const avgY = yPos(avgCount);
const maxY = yPos(maxCount);
const minY = yPos(minCount);

// Week label: "W05" from "2026-W05"
function weekLabel(w: string): string {
  return w.split('-')[1] || w;
}
---

<div class="trend-container">
  <div class="trend-header">
    <h3>Weekly Policy Activity</h3>
    <div class="trend-stats">
      <span class="trend-stat">
        <span class="trend-stat-dot trend-stat-max"></span>
        Max {maxCount}
      </span>
      <span class="trend-stat">
        <span class="trend-stat-dot trend-stat-avg"></span>
        Avg {Math.round(avgCount)}
      </span>
      <span class="trend-stat">
        <span class="trend-stat-dot trend-stat-min"></span>
        Min {minCount}
      </span>
    </div>
  </div>

  {trends.length === 0 ? (
    <p class="trend-empty">No weekly trend data available yet.</p>
  ) : (
    <div class="trend-svg-wrap">
      <svg
        viewBox={`0 0 ${svgWidth} ${svgHeight}`}
        class="trend-svg"
        role="img"
        aria-label={`Bar chart showing weekly policy counts for the last ${barCount} weeks`}
      >
        {/* Y-axis gridlines */}
        {[0, 0.25, 0.5, 0.75, 1].map(frac => {
          const val = Math.round(yMax * frac);
          const y = yPos(val);
          return (
            <g>
              <line
                x1={padLeft} y1={y}
                x2={svgWidth - padRight} y2={y}
                class="trend-gridline"
              />
              <text x={padLeft - 6} y={y + 3} class="trend-y-label">{val}</text>
            </g>
          );
        })}

        {/* Average reference line */}
        <line
          x1={padLeft} y1={avgY}
          x2={svgWidth - padRight} y2={avgY}
          class="trend-ref-line trend-ref-avg"
        />
        <text x={svgWidth - padRight + 4} y={avgY + 3} class="trend-ref-label">avg</text>

        {/* Bars */}
        {trends.map((t, i) => {
          const barH = (t.count / yMax) * chartH;
          const x = xBar(i);
          const y = yPos(t.count);
          const isMax = t.count === maxCount;
          const isMin = t.count === minCount && barCount > 1;
          return (
            <g>
              <rect
                x={x}
                y={y}
                width={barWidth}
                height={Math.max(barH, 1)}
                rx="3"
                class={`trend-bar ${isMax ? 'trend-bar-max' : ''} ${isMin ? 'trend-bar-min' : ''}`}
              />
              {/* Value label on bar */}
              <text
                x={x + barWidth / 2}
                y={y - 6}
                class="trend-val-label"
              >{t.count}</text>
              {/* Week label */}
              <text
                x={x + barWidth / 2}
                y={svgHeight - padBottom + 16}
                class="trend-x-label"
              >{weekLabel(t.week)}</text>
            </g>
          );
        })}
      </svg>
    </div>
  )}
</div>

<style>
  .trend-container {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-card);
    margin-bottom: var(--space-xl);
  }
  .trend-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
    gap: 8px;
  }
  .trend-header h3 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .trend-stats {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .trend-stat {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.625rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .trend-stat-dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
  }
  .trend-stat-max {
    background: var(--color-accent, #2563eb);
  }
  .trend-stat-avg {
    background: var(--color-text-muted, #9ca3af);
    opacity: 0.6;
  }
  .trend-stat-min {
    background: var(--color-text-dim, #d1d5db);
  }

  .trend-empty {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-align: center;
    padding: var(--space-xl) 0;
  }

  .trend-svg-wrap {
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }
  .trend-svg {
    width: 100%;
    height: auto;
    display: block;
    min-width: 400px;
  }

  /* Gridlines */
  .trend-gridline {
    stroke: var(--color-border-light, #e5e7eb);
    stroke-width: 1;
    stroke-dasharray: 3 3;
  }
  :global([data-theme="dark"]) .trend-gridline {
    stroke: var(--color-border, #333);
  }

  /* Y-axis labels */
  .trend-y-label {
    font-size: 10px;
    fill: var(--color-text-dim, #9ca3af);
    text-anchor: end;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* X-axis labels */
  .trend-x-label {
    font-size: 10px;
    fill: var(--color-text-muted, #6b7280);
    text-anchor: middle;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
  }

  /* Value labels on bars */
  .trend-val-label {
    font-size: 10px;
    fill: var(--color-text-secondary, #4b5563);
    text-anchor: middle;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 600;
  }

  /* Reference lines */
  .trend-ref-line {
    stroke-width: 1;
    stroke-dasharray: 5 3;
  }
  .trend-ref-avg {
    stroke: var(--color-text-muted, #9ca3af);
    opacity: 0.5;
  }
  .trend-ref-label {
    font-size: 9px;
    fill: var(--color-text-dim, #9ca3af);
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Bars */
  .trend-bar {
    fill: var(--color-accent, #2563eb);
    opacity: 0.75;
    transition: opacity 0.15s;
  }
  .trend-bar:hover {
    opacity: 1;
  }
  .trend-bar-max {
    opacity: 1;
  }
  .trend-bar-min {
    opacity: 0.45;
  }

  @media (max-width: 768px) {
    .trend-header {
      flex-direction: column;
    }
    .trend-svg {
      min-width: 360px;
    }
  }
</style>
